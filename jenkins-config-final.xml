<?xml version='1.1' encoding='UTF-8'?>
<project>
  <description>Web3 Scan 배치 작업 (YouTube 요약, Gemini 이미지 생성)</description>
  <keepDependencies>false</keepDependencies>
  <properties>
    <com.coravy.hudson.plugins.github.GithubProjectProperty plugin="github@1.37.0">
      <projectUrl>https://github.com/boxfox-lab/web3-scan-batch-bot/</projectUrl>
      <displayName></displayName>
    </com.coravy.hudson.plugins.github.GithubProjectProperty>
  </properties>
  <scm class="hudson.plugins.git.GitSCM" plugin="git@5.0.0">
    <configVersion>2</configVersion>
    <userRemoteConfigs>
      <hudson.plugins.git.UserRemoteConfig>
        <url>https://github.com/boxfox-lab/web3-scan-batch-bot.git</url>
      </hudson.plugins.git.UserRemoteConfig>
    </userRemoteConfigs>
    <branches>
      <hudson.plugins.git.BranchSpec>
        <name>*/dev</name>
      </hudson.plugins.git.BranchSpec>
    </branches>
    <doGenerateSubmoduleConfigurations>false</doGenerateSubmoduleConfigurations>
    <submoduleCfg class="empty-list"/>
    <extensions/>
  </scm>
  <canRoam>true</canRoam>
  <disabled>false</disabled>
  <blockBuildWhenDownstreamBuilding>false</blockBuildWhenDownstreamBuilding>
  <blockBuildWhenUpstreamBuilding>false</blockBuildWhenUpstreamBuilding>
  <triggers>
    <hudson.triggers.SCMTrigger>
      <spec>H/5 * * * *</spec>
      <ignorePostCommitHooks>false</ignorePostCommitHooks>
    </hudson.triggers.SCMTrigger>
  </triggers>
  <concurrentBuild>false</concurrentBuild>
  <builders>
    <hudson.tasks.Shell>
      <command>#!/bin/bash
set -e

# NVM 초기화
export NVM_DIR="/opt/nvm"
source "$NVM_DIR/nvm.sh"
nvm use 21

echo "========================================="
echo "🔧 Step 1: Install Dependencies"
echo "========================================="
yarn install --frozen-lockfile

echo ""
echo "========================================="
echo "🧪 Step 2: Run Tests"
echo "========================================="
yarn test

echo ""
echo "========================================="
echo "🏗️ Step 3: Build"
echo "========================================="
rm -rf dist
yarn build

echo ""
echo "========================================="
echo "✅ Step 4: Build Success - QA Notification"
echo "========================================="
if [ -n "$DISCORD_DEV_WEBHOOK_URL" ]; then
  curl -X POST -H "Content-Type: application/json" \
    -d "{\"content\": \"🚀 **${JOB_NAME}** (web3-scan-batch-bot) build #${BUILD_NUMBER} successful! \\nCheck it out: ${BUILD_URL}\"}" \
    ${DISCORD_DEV_WEBHOOK_URL}
else
  echo "⚠️ DISCORD_DEV_WEBHOOK_URL not set, skipping notification"
fi

echo ""
echo "========================================="
echo "🚀 Step 5: Deploy"
echo "========================================="
yarn deploy

echo ""
echo "========================================="
echo "✨ All Steps Completed!"
echo "========================================="</command>
      <configuredLocalRules/>
    </hudson.tasks.Shell>
  </builders>
  <publishers/>
  <buildWrappers>
    <org.jenkinsci.plugins.credentialsbinding.impl.SecretBuildWrapper plugin="credentials-binding@1.27">
      <bindings>
        <org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
          <credentialsId>OPENAI_API_KEY</credentialsId>
          <variable>OPENAI_API_KEY</variable>
        </org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
        <org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
          <credentialsId>GEMINI_API_KEY</credentialsId>
          <variable>GEMINI_API_KEY</variable>
        </org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
        <org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
          <credentialsId>YOUTUBE_API_KEY</credentialsId>
          <variable>YOUTUBE_API_KEY</variable>
        </org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
        <org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
          <credentialsId>GOOGLE_SEARCH_API_KEY</credentialsId>
          <variable>GOOGLE_SEARCH_API_KEY</variable>
        </org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
        <org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
          <credentialsId>GOOGLE_SEARCH_ENGINE_ID</credentialsId>
          <variable>GOOGLE_SEARCH_ENGINE_ID</variable>
        </org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
        <org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
          <credentialsId>DISCORD_DEV_WEBHOOK_URL</credentialsId>
          <variable>DISCORD_DEV_WEBHOOK_URL</variable>
        </org.jenkinsci.plugins.credentialsbinding.impl.StringBinding>
      </bindings>
    </org.jenkinsci.plugins.credentialsbinding.impl.SecretBuildWrapper>
  </buildWrappers>
</project>
